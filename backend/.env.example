# ── RepoGuardian Configuration ─────────────────────

# GitHub App (create at github.com/settings/apps)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# AI Provider (OpenAI / any OpenAI-compatible API)
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# Database
DATABASE_URL=sqlite:///./repoguardian.db

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
